# =============================================================================
# Yield Fortress Optimizer — agent runtime env
# Inside the iExec TDX enclave these values are sealed; outside they MUST stay
# in .env (gitignored). Never commit a populated copy.
# =============================================================================

# --- Model provider (executed *inside* the TEE) ------------------------------
MODEL_PROVIDER=openai            # openai | anthropic | local
MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Chain access ------------------------------------------------------------
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
AGENT_PRIVATE_KEY=               # hot key used to call vault.fulfilRebalance
CONFIDENTIAL_VAULT_ADDRESS=
CONFIDENTIAL_TOKEN_ADDRESS=

# --- iExec / Nox -------------------------------------------------------------
IEXEC_CHAIN=bellecour
IEXEC_WORKERPOOL=tdx-labs.pools.iexec.eth
IEXEC_APP_ADDRESS=
IEXEC_DATASET_ADDRESS=
IEXEC_TEE_FRAMEWORK=tdx          # TDX (Intel) — confidential model verification

# --- Optimiser knobs ---------------------------------------------------------
REBALANCE_MIN_BPS_DELTA=25       # only rebalance when expected APY moves >= 0.25 %
MAX_ALLOC_PER_STRATEGY_BPS=6000  # 60 % cap per strategy
RISK_PROFILE=institutional       # institutional | balanced | aggressive
