# =============================================================================
# Confidential AI Yield Fortress — frontend env
# Copy to .env.local and fill in. NEVER commit .env.local.
# =============================================================================

# --- Chain ------------------------------------------------------------------
# Arbitrum Sepolia (chainId 421614) is the only supported chain in BUILD 1.
NEXT_PUBLIC_CHAIN_ID=421614
NEXT_PUBLIC_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# --- Deployed contract addresses (from `pnpm run deploy:arbsepolia`) --------
NEXT_PUBLIC_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ASSET_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SHARE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# --- WalletConnect ----------------------------------------------------------
# Get a free Project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Branding (optional) ----------------------------------------------------
NEXT_PUBLIC_APP_NAME="Confidential AI Yield Fortress"

# --- Faucet (server-side only — DO NOT prefix with NEXT_PUBLIC_) ------------
# The "Mint Test cUSD" button hits /api/faucet which signs a confidentialMint()
# call from this account. Must be the wallet that holds the `minter` role on
# the asset token (the deploy script sets this to the deployer).
# On Vercel: add as a project environment variable, NOT a build-time secret.
FAUCET_PRIVATE_KEY=
# Optional override (defaults to NEXT_PUBLIC_RPC_URL for the same chain).
FAUCET_RPC_URL=
